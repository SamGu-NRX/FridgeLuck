# Copy to .env.gcp and replace the placeholder values.
#
# This file is for Google Cloud bootstrap + deploy commands, not for the
# runtime Node process itself.

# Required: your Google Cloud project ID.
GOOGLE_CLOUD_PROJECT=your-project-id

# Recommended Gemini / Cloud Run region for this repo.
GOOGLE_CLOUD_LOCATION=us-central1

# Cloud Run service and Artifact Registry repository names.
SERVICE_NAME=fridgeluck-gemini-agent
ARTIFACT_REGISTRY_REPO=fridgeluck

# Runtime service account name (without the @project.iam.gserviceaccount.com suffix).
SERVICE_ACCOUNT_NAME=fridgeluck-gemini-agent

# Firestore collection used by the live session store.
FIRESTORE_COLLECTION=liveSessions

# Gemini model defaults used by this backend.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_RECIPE_MODEL=gemini-2.5-flash
GEMINI_RANKING_MODEL=gemini-2.5-flash

# Optional runtime knobs.
GROUNDING_ENABLED=true
PORT=8080
