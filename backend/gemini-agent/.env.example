# Shared
PORT=8080
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_RECIPE_MODEL=gemini-2.5-flash
GEMINI_RANKING_MODEL=gemini-2.5-flash
LIVE_SESSION_STORE_MODE=auto
FIRESTORE_COLLECTION=liveSessions
GROUNDING_ENABLED=true

# Choose one auth mode:

# 1) Vertex AI mode (recommended for Cloud Run)
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# 2) Developer API mode (local quick start)
# GOOGLE_GENAI_USE_VERTEXAI=false
# GEMINI_API_KEY=your-key
